{
  "id": "pregnancy-care",
  "fields": [
    {
      "name": "personName",
      "type": "text",
      "required": false
    },
    {
      "name": "conceptionDate",
      "type": "date",
      "required": true
    },
    {
      "name": "highRisk",
      "type": "select",
      "required": true,
      "defaultValue": "standard",
      "options": [
        {
          "value": "standard"
        },
        {
          "value": "high"
        }
      ]
    },
    {
      "name": "country",
      "type": "select",
      "required": true,
      "defaultValue": "global",
      "options": [
        {
          "value": "global"
        },
        {
          "value": "chile"
        }
      ]
    },
    {
      "name": "lastTdapDate",
      "type": "date",
      "required": false
    }
  ],
  "derivedDates": [
    {
      "name": "dueDate",
      "fromField": "conceptionDate",
      "addDays": 280
    },
    {
      "name": "postpartumDate",
      "fromDerived": "dueDate",
      "addDays": 42
    }
  ],
  "calculationWindow": {
    "startAnchor": "conceptionDate",
    "endAnchor": "postpartumDate",
    "futureOnly": true
  },

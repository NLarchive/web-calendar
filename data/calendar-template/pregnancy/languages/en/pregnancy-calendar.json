{
  "title": "Pregnancy Care Calendar Calculator",
  "description": "Data-driven pregnancy timeline from conception (week 0) through postpartum follow-up.",
  "disclaimer": "Educational schedule template only. Clinical timing must be personalized by your OB/GYN or healthcare team.",
  "fields": [
    {
      "name": "personName",
      "label": "Person name",
      "placeholder": "Ana",
      "options": []
    },
    {
      "name": "conceptionDate",
      "label": "Conception date",
      "options": []
    },
    {
      "name": "highRisk",
      "label": "Risk profile",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "high",
          "label": "High-risk follow-up"
        }
      ]
    },
    {
      "name": "country",
      "label": "Country / Region Guidelines",
      "options": [
        {
          "value": "global",
          "label": "Global (WHO/NICE/ACOG)"
        },
        {
          "value": "chile",
          "label": "Chile (MINSAL public schedule)"
        }
      ]
    },
    {
      "name": "lastTdapDate",
      "label": "Last Tdap date (optional)",
      "options": []
    }
  ],
  "events": [
    {
      "id": "prenatal-initial",
      "titleTemplate": "First prenatal consultation{entitySuffix}",
      "description": "Initial prenatal evaluation and baseline care plan."
    },
    {
      "id": "dating-ultrasound",
      "titleTemplate": "Dating ultrasound (11-14 weeks){entitySuffix}",
      "description": "Global recommendation: dating scan in late first trimester with optional combined screening."
    },
    {
      "id": "dating-ultrasound-chile",
      "titleTemplate": "Early ultrasound (Chile pathway){entitySuffix}",
      "description": "Chile pathway: perform early pregnancy ultrasound before week 20, ideally first trimester when available."
    },
    {
      "id": "nuchal-translucency",
      "titleTemplate": "Nuchal translucency / first trimester screening{entitySuffix}",
      "description": "First trimester screening milestone."
    },
    {
      "id": "anatomy-ultrasound",
      "titleTemplate": "Anatomy ultrasound (18-22 weeks){entitySuffix}",
      "description": "Global recommendation: detailed anomaly scan around 18-22 weeks."
    },
    {
      "id": "anatomy-ultrasound-chile",
      "titleTemplate": "Anatomy ultrasound (Chile 20-24 weeks){entitySuffix}",
      "description": "Chile pathway: structural anatomy scan around 20-24 weeks."
    },
    {
      "id": "gdm-screening",
      "titleTemplate": "Gestational diabetes screening{entitySuffix}",
      "description": "Typical oral glucose screening milestone."
    },
    {
      "id": "routine-control-30w",

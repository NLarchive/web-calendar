{
  "id": "vet-care",
  "fields": [
    {
      "name": "petName",
      "type": "text",
      "required": false
    },
    {
      "name": "species",
      "type": "select",
      "required": true,
      "defaultValue": "dog",
      "options": [
        {
          "value": "dog"
        },
        {
          "value": "cat"
        }
      ]
    },
    {
      "name": "birthDate",
      "type": "date",
      "required": false
    },
    {
      "name": "ageYears",
      "type": "number",
      "required": true,
      "min": 0,
      "max": 18
    },
    {
      "name": "lastVaccine",
      "type": "date",
      "required": true
    },
    {
      "name": "lastDeworming",
      "type": "date",
      "required": true
    },
    {
      "name": "lastEctoparasite",
      "type": "date",
      "required": true
    },
    {
      "name": "lastCheckup",
      "type": "date",
      "required": true
    },
    {
      "name": "environment",
      "type": "select",
      "required": true,
      "defaultValue": "indoor",
      "options": [
        {
          "value": "indoor"
        },
        {
          "value": "mixed"
        },
        {
          "value": "outdoor"
        }
      ]
    },
    {
      "name": "country",
      "type": "select",
      "required": true,
      "defaultValue": "global",
      "options": [
        {
          "value": "global"
        },
        {
          "value": "chile"
        }
      ]
    }
  ],
  "derivedDates": [
    {
      "name": "birthDateDerived",
      "fromField": "birthDate",
      "fallbackFromAgeYearsField": "ageYears"
    },
    {
      "name": "endOfLifeDate",
      "fromDerived": "birthDateDerived",
      "addDays": 6574
    }
  ],
  "calculationWindow": {
    "startAnchor": "birthDateDerived",
    "endAnchor": "endOfLifeDate",
    "futureOnly": true
  },
